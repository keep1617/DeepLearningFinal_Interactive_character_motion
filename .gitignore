# Python/cache
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local environments
.env
.venv/
venv/
env/

# Generated demo artifacts
outputs/
scripts/outputs/
scripts/mic_input.wav
examples/out/

